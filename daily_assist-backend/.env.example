NODE_ENV=development
PORT=4000
CORS_ORIGIN=*
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dailyassist
JWT_ACCESS_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_REFRESH_SECRET=replace_with_a_long_random_string_at_least_32_chars
